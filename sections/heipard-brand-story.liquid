{% comment %}
  HeiPard Brand-Story — zweispaltig (Bild + Text)
  Kicker "Ueber HeiPard", H2 zweizeilig (2. Zeile Terracotta), Fliesstext, Link.
  Optik aus docs/lovable-reference (routes/index.tsx).
  ACHTUNG (RECHTLICH): Prototyp-Text "Wir entwickeln Lichter" wurde bewusst auf
  "Wir bringen dir Lichter" geaendert (Content-Regel: kein "entwickelt"/
  Herkunfts-Andeutung). Finale Formulierung ist [TBD] -> docs/heipard-offene-punkte.md.
{% endcomment %}

<section class="heipard-section heipard-story color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="heipard-story__grid heipard-story__grid--{{ section.settings.image_position }}">
      <div class="heipard-story__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              class: 'heipard-story__img',
              loading: 'lazy',
              widths: '500, 750, 1000, 1200',
              sizes: '(min-width: 900px) 50vw, 100vw',
              alt: section.settings.image.alt | default: shop.name
          }}
        {%- else -%}
          <span class="heipard-story__img heipard-story__fallback" aria-hidden="true"></span>
        {%- endif -%}
      </div>

      <div class="heipard-story__text">
        {%- if section.settings.kicker != blank -%}
          <span class="heipard-kicker">{{ section.settings.kicker | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank or section.settings.heading_accent != blank -%}
          <h2 class="heipard-story__heading">
            {{ section.settings.heading | escape }}
            {%- if section.settings.heading_accent != blank %}
              <br><span class="heipard-story__accent">{{ section.settings.heading_accent | escape }}</span>
            {%- endif -%}
          </h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="heipard-story__body rte">{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.link_label != blank -%}
          <a class="heipard-story__link" href="{{ section.settings.link | default: '#' }}">
            {{ section.settings.link_label | escape }}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.heipard-story__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(2.5rem, 5vw, 5rem);
  align-items: center;
}

.heipard-story__media {
  position: relative;
  aspect-ratio: 4 / 5;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  isolation: isolate;
  box-shadow:
    0 1px 2px color-mix(in oklch, rgb(var(--color-foreground)) 8%, transparent),
    0 12px 36px -10px color-mix(in oklch, var(--glow) 35%, transparent);
}

.heipard-story__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.heipard-story__fallback {
  background:
    radial-gradient(120% 90% at 75% 100%, color-mix(in oklch, var(--brand) 45%, transparent) 0%, transparent 60%),
    linear-gradient(160deg, var(--secondary) 0%, var(--muted) 100%);
}

.heipard-story__heading {
  margin: 0;
  font-family: var(--font-heipard-display);
  font-weight: 500;
  letter-spacing: -0.02em;
  line-height: 1.08;
  font-size: clamp(2.8rem, 3vw + 1.6rem, 4.8rem);
  color: rgb(var(--color-foreground));
}

.heipard-story__accent {
  color: var(--primary);
}

.heipard-story__body {
  margin-top: 1.8rem;
  max-width: 52ch;
  font-size: clamp(1.6rem, 0.4vw + 1.5rem, 1.8rem);
  line-height: 1.65;
  color: color-mix(in oklch, rgb(var(--color-foreground)) 68%, transparent);
}

.heipard-story__link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 2.4rem;
  font-size: 1.5rem;
  text-decoration: none;
  color: color-mix(in oklch, rgb(var(--color-foreground)) 85%, transparent);
  transition: color 200ms ease;
}

.heipard-story__link:hover {
  color: var(--primary);
}

@media screen and (min-width: 900px) {
  .heipard-story__grid {
    grid-template-columns: 1fr 1fr;
  }
  .heipard-story__grid--right .heipard-story__media {
    order: 2;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "HeiPard Brand-Story",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Über HeiPard" },
    { "type": "text", "id": "heading", "label": "Ueberschrift Zeile 1", "default": "Heimat am Niederrhein." },
    { "type": "text", "id": "heading_accent", "label": "Ueberschrift Zeile 2 (Terracotta)", "default": "Licht für deine schönsten Stunden." },
    { "type": "richtext", "id": "body", "label": "Text", "default": "<p>HeiPard ist zuhause am Niederrhein. Wir bringen dir Lichter, die Räume verwandeln und Abende verlängern. Jede Lichterkette wird geprüft, bevor sie zu dir reist — und unser Service spricht deine Sprache.</p>" },
    { "type": "text", "id": "link_label", "label": "Link-Text", "default": "Mehr über HeiPard" },
    { "type": "url", "id": "link", "label": "Link-Ziel" },
    { "type": "image_picker", "id": "image", "label": "Bild" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bild-Position (Desktop)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-1" }
  ],
  "presets": [{ "name": "HeiPard Brand-Story" }]
}
{% endschema %}

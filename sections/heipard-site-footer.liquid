{% comment %}
  HeiPard Footer — Struktur 1:1 aus docs/lovable-reference (site-footer.tsx):
  Markenspalte + Beschreibung · Kategorien · Service · Newsletter (mit Text) ·
  Bottom-Bar (Copyright + Rechtliches + Land/Waehrung).
  WICHTIG: Lovables Telefon/E-Mail/"10 %" sind Halluzinationen -> hier als [TBD]
  (echte Werte in der [TBD]-Runde). Newsletter nutzt Shopifys Kundenformular.
  Styles: assets/heipard-footer.css (global, laedt nach base.css -> Abstaende
  werden nicht von Dawn-Klassen genullt).
{% endcomment %}

<footer class="heipard-footer color-{{ section.settings.color_scheme }}">
  <div class="page-width heipard-footer__top">

    <div class="heipard-footer__brand">
      <a href="{{ routes.root_url }}" class="heipard-footer__logo">{% render 'heipard-wordmark' %}</a>
      {%- if section.settings.brand_description != blank -%}
        <p class="heipard-footer__desc">{{ section.settings.brand_description | escape }}</p>
      {%- endif -%}
    </div>

    <div class="heipard-footer__col">
      <h4 class="heipard-footer__heading">{{ section.settings.categories_heading | escape }}</h4>
      {%- if section.settings.categories_menu != blank -%}
        <ul class="heipard-footer__links">
          {%- for link in section.settings.categories_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="heipard-footer__col">
      <h4 class="heipard-footer__heading">{{ section.settings.service_heading | escape }}</h4>
      <ul class="heipard-footer__links">
        <li>
          {%- if section.settings.service_phone != blank -%}
            <a href="tel:{{ section.settings.service_phone | replace: ' ', '' }}">{{ section.settings.service_phone | escape }}</a>
          {%- else -%}
            <span class="heipard-footer__tbd">[TBD: Telefon]</span>
          {%- endif -%}
        </li>
        {%- if section.settings.service_hours != blank -%}
          <li>{{ section.settings.service_hours | escape }}</li>
        {%- endif -%}
        <li>
          {%- if section.settings.service_email != blank -%}
            <a href="mailto:{{ section.settings.service_email }}">{{ section.settings.service_email | escape }}</a>
          {%- else -%}
            <span class="heipard-footer__tbd">[TBD: E-Mail]</span>
          {%- endif -%}
        </li>
        <li><a href="{{ section.settings.help_link | default: '#' }}">Hilfe &amp; FAQ</a></li>
        <li><a href="{{ section.settings.dealer_link | default: '#' }}">Händler werden</a></li>
      </ul>
    </div>

    <div class="heipard-footer__col heipard-footer__newsletter">
      <h4 class="heipard-footer__heading">{{ section.settings.newsletter_heading | escape }}</h4>
      {%- if section.settings.newsletter_text != blank -%}
        <p class="heipard-footer__desc">{{ section.settings.newsletter_text | escape }}</p>
      {%- endif -%}
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="heipard-footer__nl-row">
          <input
            type="email"
            name="contact[email]"
            class="heipard-footer__nl-input"
            placeholder="deine@email.de"
            aria-label="E-Mail-Adresse"
            required
          >
          <button type="submit" class="heipard-footer__nl-btn">Anmelden</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="heipard-footer__nl-note">Danke! Schau in dein Postfach zur Bestätigung.</p>
        {%- elsif form.errors -%}
          <p class="heipard-footer__nl-note heipard-footer__nl-note--error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  <div class="heipard-footer__bottom">
    <div class="page-width heipard-footer__bottom-inner">
      <p class="heipard-footer__copyright">&copy; {{ 'now' | date: '%Y' }} HeiPard &mdash; eine Marke der C&amp;L Handels GmbH</p>

      <ul class="heipard-footer__legal">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if localization.available_countries.size > 1 -%}
        <div class="heipard-footer__locale">
          {%- form 'localization' -%}
            <label class="visually-hidden" for="FooterCountrySelect">Land / Region</label>
            <select id="FooterCountrySelect" name="country_code" class="heipard-footer__locale-select" onchange="this.form.submit()">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                  {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                </option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "HeiPard Footer",
  "settings": [
    { "type": "textarea", "id": "brand_description", "label": "Marken-Beschreibung", "default": "Stimmungsvolle Beleuchtung vom Niederrhein. Für drinnen, draußen und unterwegs." },
    { "type": "text", "id": "categories_heading", "label": "Spalte 2 – Überschrift", "default": "Kategorien" },
    { "type": "link_list", "id": "categories_menu", "label": "Spalte 2 – Menü", "default": "main-menu" },
    { "type": "text", "id": "service_heading", "label": "Spalte 3 – Überschrift", "default": "Service" },
    { "type": "text", "id": "service_phone", "label": "Service – Telefon (leer = [TBD])" },
    { "type": "text", "id": "service_hours", "label": "Service – Zeiten", "default": "Mo–Fr 9–16 Uhr" },
    { "type": "text", "id": "service_email", "label": "Service – E-Mail (leer = [TBD])" },
    { "type": "url", "id": "help_link", "label": "Service – Hilfe & FAQ Link" },
    { "type": "url", "id": "dealer_link", "label": "Service – Händler-werden Link" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter – Überschrift", "default": "Bleib auf dem Laufenden" },
    { "type": "textarea", "id": "newsletter_text", "label": "Newsletter – Text", "default": "Neue Kollektionen und Inspirationen direkt in dein Postfach." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-1" }
  ],
  "presets": [{ "name": "HeiPard Footer" }]
}
{% endschema %}

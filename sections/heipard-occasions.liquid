{% comment %}
  HeiPard Anlaesse — 4 farbige Kacheln (Aspect 3/4)
  Kicker "Anlaesse" + H2 "Fuer jeden Moment das passende Licht".
  Optik/Texte 1:1 aus docs/lovable-reference (routes/index.tsx, occasions-Array).
  "Immer farbig": ohne Bild zeigt ein warmer Farbverlauf statt neutralem Grau.
  Kacheln editierbar (Name/Bild/Link).
{% endcomment %}

<section class="heipard-section heipard-occasions color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="heipard-section__head">
      <div>
        {%- if section.settings.kicker != blank -%}
          <span class="heipard-kicker">{{ section.settings.kicker | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="heipard-section__heading heipard-occasions__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
    </div>

    <div class="heipard-occasions__grid">
      {%- for block in section.blocks -%}
        <a class="heipard-occasion" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                class: 'heipard-occasion__img',
                loading: 'lazy',
                widths: '300, 450, 600, 900',
                sizes: '(min-width: 990px) 25vw, 50vw',
                alt: block.settings.name | default: block.settings.image.alt
            }}
          {%- else -%}
            <span class="heipard-occasion__img heipard-occasion__fallback" aria-hidden="true"></span>
          {%- endif -%}
          <span class="heipard-occasion__scrim" aria-hidden="true"></span>
          {%- if block.settings.name != blank -%}
            <span class="heipard-occasion__name">{{ block.settings.name | escape }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.heipard-occasions__heading {
  max-width: 20ch;
}

.heipard-occasions__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.6rem;
}

@media screen and (min-width: 990px) {
  .heipard-occasions__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.heipard-occasion {
  position: relative;
  display: block;
  aspect-ratio: 3 / 4;
  border-radius: var(--radius-xl);
  overflow: hidden;
  isolation: isolate;
  text-decoration: none;
  box-shadow:
    0 1px 2px color-mix(in oklch, rgb(var(--color-foreground)) 8%, transparent),
    0 8px 24px -8px color-mix(in oklch, var(--glow) 25%, transparent);
  transition: box-shadow 350ms ease;
}

.heipard-occasion:hover,
.heipard-occasion:focus-visible {
  box-shadow:
    0 2px 4px color-mix(in oklch, rgb(var(--color-foreground)) 10%, transparent),
    0 16px 48px -12px color-mix(in oklch, var(--glow) 55%, transparent);
}

.heipard-occasion__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: -2;
  transition: transform 1400ms cubic-bezier(0.22, 1, 0.36, 1);
}

.heipard-occasion:hover .heipard-occasion__img {
  transform: scale(1.1);
}

.heipard-occasion__fallback {
  background:
    radial-gradient(110% 80% at 30% 15%, color-mix(in oklch, var(--heipard-accent-bright) 55%, transparent) 0%, transparent 55%),
    linear-gradient(155deg, var(--brand) 0%, var(--primary) 45%, var(--secondary) 100%);
}

.heipard-occasion__scrim {
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.2) 45%, transparent 75%);
}

.heipard-occasion__name {
  position: absolute;
  inset-inline: 0;
  bottom: 0;
  padding: 1.8rem;
  font-family: var(--font-heipard-display);
  font-weight: 500;
  letter-spacing: -0.01em;
  font-size: clamp(1.9rem, 1vw + 1.6rem, 2.4rem);
  line-height: 1.1;
  color: oklch(0.98 0.01 80);
}

@media (prefers-reduced-motion: reduce) {
  .heipard-occasion__img { transition: none; }
  .heipard-occasion:hover .heipard-occasion__img { transform: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "HeiPard Anlaesse",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Anlässe" },
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Für jeden Moment das passende Licht" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Anlass",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Anlass" },
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "HeiPard Anlaesse",
      "blocks": [
        { "type": "occasion", "settings": { "name": "Weihnachten" } },
        { "type": "occasion", "settings": { "name": "Garten & Balkon" } },
        { "type": "occasion", "settings": { "name": "Camping" } },
        { "type": "occasion", "settings": { "name": "Hochzeit & Party" } }
      ]
    }
  ]
}
{% endschema %}

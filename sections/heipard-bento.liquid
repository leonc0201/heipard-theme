{% comment %}
  HeiPard Kategorie-Bento — asymmetrisches Kachel-Grid
  Optik/Texte 1:1 aus docs/lovable-reference (routes/index.tsx, categories-Array).
  Kacheln editierbar (Bloecke): Groesse, Kicker, Titel, Bild, Link.
{% endcomment %}

<section class="heipard-section heipard-bento color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="heipard-section__head">
      <div>
        {%- if section.settings.kicker != blank -%}
          <span class="heipard-kicker">{{ section.settings.kicker | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="heipard-section__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a class="heipard-section__link" href="{{ section.settings.view_all_link | default: '#' }}">
          {{ section.settings.view_all_label | escape }}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="heipard-bento__grid">
      {%- for block in section.blocks -%}
        <a
          class="heipard-bento__tile heipard-bento__tile--{{ block.settings.size }}"
          href="{{ block.settings.link | default: '#' }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1400
              | image_tag:
                class: 'heipard-bento__image',
                loading: 'lazy',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '400, 600, 900, 1200, 1400',
                alt: block.settings.title | default: block.settings.image.alt
            }}
          {%- else -%}
            <span class="heipard-bento__image heipard-bento__fallback" aria-hidden="true"></span>
          {%- endif -%}
          <span class="heipard-bento__scrim" aria-hidden="true"></span>
          <span class="heipard-bento__content">
            {%- if block.settings.kicker != blank -%}
              <span class="heipard-bento__desc">{{ block.settings.kicker | escape }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <span class="heipard-bento__title">{{ block.settings.title | escape }}</span>
            {%- endif -%}
            <span class="heipard-bento__cta">
              Entdecken
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
            </span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.heipard-bento__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: 180px;
  gap: 1.4rem;
}

.heipard-bento__tile {
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: var(--radius-xl);
  text-decoration: none;
  isolation: isolate;
  grid-column: span 1;
  box-shadow:
    0 1px 2px color-mix(in oklch, rgb(var(--color-foreground)) 8%, transparent),
    0 8px 24px -8px color-mix(in oklch, var(--glow) 25%, transparent);
  transition: box-shadow 350ms ease, transform 350ms ease;
}

.heipard-bento__tile:hover {
  box-shadow:
    0 2px 4px color-mix(in oklch, rgb(var(--color-foreground)) 10%, transparent),
    0 16px 48px -12px color-mix(in oklch, var(--glow) 55%, transparent);
}

.heipard-bento__tile--feature,
.heipard-bento__tile--tall {
  grid-column: span 2;
}

.heipard-bento__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: -2;
  transition: transform 1200ms cubic-bezier(0.22, 1, 0.36, 1);
}

.heipard-bento__tile:hover .heipard-bento__image {
  transform: scale(1.05);
}

.heipard-bento__fallback {
  background:
    radial-gradient(120% 90% at 80% 110%, color-mix(in oklch, var(--brand) 50%, transparent) 0%, transparent 60%),
    linear-gradient(160deg, var(--secondary) 0%, var(--muted) 100%);
}

.heipard-bento__scrim {
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.15) 45%, transparent 75%);
}

.heipard-bento__content {
  position: absolute;
  inset-inline: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 2rem;
  color: oklch(0.98 0.01 80);
}

.heipard-bento__desc {
  font-size: 1.2rem;
  color: color-mix(in oklch, oklch(0.98 0.01 80) 72%, transparent);
}

.heipard-bento__title {
  font-family: var(--font-heipard-display);
  font-weight: 500;
  letter-spacing: -0.01em;
  font-size: clamp(1.9rem, 1vw + 1.6rem, 2.4rem);
  line-height: 1.1;
}

.heipard-bento__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.6rem;
  font-size: 1.2rem;
  color: color-mix(in oklch, oklch(0.98 0.01 80) 92%, transparent);
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity 400ms ease, transform 400ms ease;
}

.heipard-bento__tile:hover .heipard-bento__cta,
.heipard-bento__tile:focus-visible .heipard-bento__cta {
  opacity: 1;
  transform: translateX(0);
}

@media screen and (min-width: 750px) {
  .heipard-bento__grid {
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 200px;
    gap: 1.6rem;
  }
  .heipard-bento__tile--feature { grid-column: span 4; grid-row: span 2; }
  .heipard-bento__tile--tall    { grid-column: span 2; grid-row: span 3; }
  .heipard-bento__tile--medium  { grid-column: span 2; grid-row: span 2; }
  .heipard-bento__tile--banner  { grid-column: span 3; grid-row: span 1; }
}

@media (prefers-reduced-motion: reduce) {
  .heipard-bento__image,
  .heipard-bento__cta { transition: none; }
  .heipard-bento__tile:hover .heipard-bento__image { transform: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "HeiPard Bento",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Kollektionen" },
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Finde dein Licht" },
    { "type": "text", "id": "view_all_label", "label": "Link-Text (rechts)", "default": "Alles ansehen" },
    { "type": "url", "id": "view_all_link", "label": "Link-Ziel (rechts)" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Kachel",
      "settings": [
        {
          "type": "select",
          "id": "size",
          "label": "Groesse",
          "options": [
            { "value": "feature", "label": "Gross (4x2)" },
            { "value": "tall", "label": "Hoch (2x3)" },
            { "value": "medium", "label": "Mittel (2x2)" },
            { "value": "banner", "label": "Breit (3x1)" }
          ],
          "default": "medium"
        },
        { "type": "text", "id": "kicker", "label": "Kicker (klein)", "default": "Kicker" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Kategorie" },
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "HeiPard Bento",
      "blocks": [
        { "type": "tile", "settings": { "size": "feature", "kicker": "Stimmung für draußen", "title": "Party & Terrasse" } },
        { "type": "tile", "settings": { "size": "tall", "kicker": "Festlich am Fenster", "title": "Eiszapfen & Vorhang" } },
        { "type": "tile", "settings": { "size": "medium", "kicker": "Klassisch & vielseitig", "title": "Lichterketten" } },
        { "type": "tile", "settings": { "size": "medium", "kicker": "Leuchtet ohne Steckdose", "title": "Solar & Gartendeko" } },
        { "type": "tile", "settings": { "size": "banner", "kicker": "Robust für unterwegs", "title": "Camping & Outdoor" } },
        { "type": "tile", "settings": { "size": "banner", "kicker": "Per App gesteuert", "title": "Smart Lighting" } }
      ]
    }
  ]
}
{% endschema %}

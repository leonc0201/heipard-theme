{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "kicker": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% if product.type != blank %}<span class='heipard-pdp-kicker'>{{ product.type }}</span>{% elsif product.collections.first != blank %}<span class='heipard-pdp-kicker'>{{ product.collections.first.title }}</span>{% endif %}"
          }
        },
        "title": { "type": "title", "settings": {} },
        "subtitle": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% assign st = product.metafields.heipard.subtitle.value %}{% if st != blank %}<p class='heipard-pdp-subtitle'>{{ st }}</p>{% endif %}"
          }
        },
        "price": { "type": "price", "settings": {} },
        "specs": {
          "type": "custom_liquid",
          "settings": { "custom_liquid": "{% render 'heipard-product-specs', product: product %}" }
        },
        "warranty": {
          "type": "custom_liquid",
          "settings": { "custom_liquid": "{% render 'heipard-product-warranty', product: product %}" }
        },
        "quantity": { "type": "quantity_selector", "settings": {} },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": { "show_dynamic_checkout": true, "show_gift_card_recipient": false }
        },
        "description": { "type": "description", "settings": {} },
        "acc_tech": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Technische Details",
            "icon": "none",
            "content": "<p>[TBD: Technische Details werden aus den Produktdaten / Metafeldern (heipard) befüllt.]</p>"
          }
        },
        "acc_install": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Installation & Pflege",
            "icon": "none",
            "content": "<p>[TBD: Installations- und Pflegehinweise ergänzen.]</p>"
          }
        },
        "acc_ship": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Versand & Rückgabe",
            "icon": "none",
            "content": "<p>[TBD: Echte Versand- & Rückgabekonditionen einsetzen — KEINE erfundenen Angaben/Standorte.]</p>"
          }
        }
      },
      "block_order": [
        "kicker",
        "title",
        "subtitle",
        "price",
        "specs",
        "warranty",
        "quantity",
        "buy_buttons",
        "description",
        "acc_tech",
        "acc_install",
        "acc_ship"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "gallery_layout": "thumbnail",
        "media_position": "left",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 48,
        "padding_bottom": 12
      }
    },
    "heipard_feature": {
      "type": "heipard-feature",
      "blocks": {
        "f1": { "type": "feature", "settings": { "kicker": "Warmes Licht", "title": "Licht, das den Abend verlängert.", "body": "Das warmweiße Leuchten verwandelt deine Terrasse oder dein Wohnzimmer in einen Ort, an dem du gerne länger bleibst. Kein kaltes LED-Flackern, sondern echte Stimmung — so, wie du sie willst." } },
        "f2": { "type": "feature", "settings": { "kicker": "Gebaut für draussen", "title": "Regen? Kein Thema.", "body": "Vergossene Fassungen, robuste Kabel und IP-geprüfte Verbindungen halten Wetter aus, wenn dein Abend draußen länger wird. Lass sie hängen — auch wenn der Sommerregen kommt." } },
        "f3": { "type": "feature", "settings": { "kicker": "In Minuten aufgebaut", "title": "Auspacken, aufhängen, anknipsen.", "body": "Beiliegende Clips und ein durchdachtes Kabelmanagement machen das Aufhängen einfach. Innerhalb weniger Minuten leuchtet dein Abend — ohne Fummelei, ohne Werkzeugkiste." } },
        "m1": { "type": "mini", "settings": { "icon": "timer", "label": "Timer-Funktion", "text": "6 Stunden an, 18 Stunden Pause" } },
        "m2": { "type": "mini", "settings": { "icon": "modes", "label": "8 Leuchtmodi", "text": "Von ruhig bis festlich animiert" } },
        "m3": { "type": "mini", "settings": { "icon": "link", "label": "Koppelbar", "text": "Bis zu 4 Ketten miteinander verbinden" } }
      },
      "block_order": ["f1", "f2", "f3", "m1", "m2", "m3"],
      "settings": {
        "kicker": "Warum du sie lieben wirst",
        "heading": "Kleine Details,",
        "heading_accent": "große Wirkung.",
        "color_scheme": "scheme-1"
      }
    },
    "related": {
      "type": "heipard-related",
      "settings": {
        "kicker": "Passt dazu",
        "heading": "Für eine noch schönere Stimmung",
        "products_count": 4,
        "color_scheme": "scheme-1"
      }
    }
  },
  "order": ["main", "heipard_feature", "related"]
}
